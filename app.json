{
  "expo": {
    "name": "Öğrenci Nerede Yer?",
    "slug": "ogrenci-nerede-yer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "ogrenci-nerede-yer",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5A623"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.ogrencinerdeyer.app",
      "buildNumber": "1",
      "config": {
        "googleMapsApiKey": "AIzaSyBqpDYesxYX1wby51oxhPm9v6xyvQDCkDs"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yakınındaki mekanları gösterebilmemiz için konum izni gerekli.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Yakınındaki mekanları sürekli gösterebilmemiz için konum izni gerekli.",
        "NSLocationAlwaysUsageDescription": "Yakınındaki mekanları arka planda gösterebilmemiz için konum izni gerekli.",
        "NSCameraUsageDescription": "Mekan fotoğrafı çekebilmek için kamera izni gerekli.",
        "NSPhotoLibraryUsageDescription": "Galerinizden fotoğraf seçebilmek için izin gerekli.",
        "NSMicrophoneUsageDescription": "Sesli içerik kaydedebilmek için mikrofon izni gerekli."
      }
    },
    "android": {
      "package": "com.ogrencinerdeyer.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F5A623",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBqpDYesxYX1wby51oxhPm9v6xyvQDCkDs"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ],
      "softwareKeyboardLayoutMode": "adjustResize"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-location",
      "expo-image-picker",
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyBqpDYesxYX1wby51oxhPm9v6xyvQDCkDs"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-image",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#E23744"
        }
      ],
      "expo-video",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.your-ios-client-id"
        }
      ]
    ]
  }
}
